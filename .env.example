# ═══════════════════════════════════════════════════════════
#  MiroFish Lite — Environment Variables
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── LLM: Google Gemini 2.0 Flash (Free Tier) ────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Supabase: PostgreSQL + pgvector ─────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_service_role_or_anon_key_here

# ── Simulation Defaults ──────────────────────────────────────
SIMULATION_NUM_AGENTS=20
SIMULATION_NUM_ROUNDS=3
OASIS_DEFAULT_MAX_ROUNDS=3

# ── API Cost Control ─────────────────────────────────────────
MAX_API_CALLS_PER_SIMULATION=150

# ── Flask ────────────────────────────────────────────────────
FLASK_DEBUG=False
SECRET_KEY=change-me-in-production

# ── Report Agent Tuning ──────────────────────────────────────
REPORT_AGENT_MAX_TOOL_CALLS=5
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
REPORT_AGENT_TEMPERATURE=0.5
