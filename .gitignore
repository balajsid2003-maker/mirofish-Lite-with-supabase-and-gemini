# MiroFish Lite — Root .gitignore

# 🔐 Sensitive Data
.env
.env.local
.env.*.local
.logs/
backend/logs/
backend/uploads/projects/
backend/uploads/simulations/
backend/uploads/reports/
!backend/uploads/.gitkeep
!backend/logs/.gitkeep

# 🐍 Python
backend/.venv/
backend/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
.tox/
.nox/
.mypy_cache/
.ruff_cache/
backend/dist/
backend/build/

# 📦 Node
node_modules/
frontend/node_modules/
frontend/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# 🖥️ OS & Editors
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# 🐳 Docker
.docker/
